    {
      "name": "4a081c8c",
      "displayName": "Yield-Weather Correlation Summary",
      "queryLines": [
        "SELECT 'Max Temp' AS weather_feature, -0.071 AS correlation UNION ALL\n",
        "SELECT 'Min Temp', 0.094 UNION ALL\n",
        "SELECT 'Precipitation', -0.068 UNION ALL\n",
        "SELECT 'Snowfall', -0.149 UNION ALL\n",
        "SELECT 'Snow Depth', -0.330"
      ]
    },
    {
      "name": "befd8626",
      "displayName": "Yield-Weather Correlation Absolute Summary",
      "queryLines": [
        "SELECT 'Max Temp' AS weather_feature, ABS(-0.071) AS correlation UNION ALL\n",
        "SELECT 'Min Temp', ABS(0.094) UNION ALL\n",
        "SELECT 'Precipitation', ABS(-0.068) UNION ALL\n",
        "SELECT 'Snowfall', ABS(-0.149) UNION ALL\n",
        "SELECT 'Snow Depth', ABS(-0.330)"
      ]
    },
    {
      "name": "011a74b5",
      "displayName": "Yield-Weather Absolute Correlation by Crop",
      "queryLines": [
        "WITH corn AS (\n",
        "  SELECT w.state, w.year, w.avg_temp_max, w.avg_temp_min, w.avg_precip, w.avg_snowfall, w.avg_snow_depth, y.avg_yield\n",
        "  FROM workspace.number_one_awesome_team.weather_state_year w\n",
        "  JOIN workspace.number_one_awesome_team.yield_state_year_clean y\n",
        "    ON w.state = y.state AND w.year = y.year\n",
        "),\n",
        "soybean AS (\n",
        "  SELECT w.state, w.year, w.avg_temp_max, w.avg_temp_min, w.avg_precip, w.avg_snowfall, w.avg_snow_depth, y.avg_yield\n",
        "  FROM workspace.number_one_awesome_team.weather_state_year w\n",
        "  JOIN workspace.number_one_awesome_team.yield_soybean_state_year y\n",
        "    ON w.state = y.state AND w.year = y.year\n",
        "),\n",
        "correlations AS (\n",
        "  SELECT 'Corn' AS crop, 'Max Temp' AS weather_feature, ABS(CORR(avg_yield, avg_temp_max)) AS abs_corr FROM corn UNION ALL\n",
        "  SELECT 'Corn', 'Min Temp', ABS(CORR(avg_yield, avg_temp_min)) FROM corn UNION ALL\n",
        "  SELECT 'Corn', 'Precipitation', ABS(CORR(avg_yield, avg_precip)) FROM corn UNION ALL\n",
        "  SELECT 'Corn', 'Snowfall', ABS(CORR(avg_yield, avg_snowfall)) FROM corn UNION ALL\n",
        "  SELECT 'Corn', 'Snow Depth', ABS(CORR(avg_yield, avg_snow_depth)) FROM corn UNION ALL\n",
        "  SELECT 'Soybean', 'Max Temp', ABS(CORR(avg_yield, avg_temp_max)) FROM soybean UNION ALL\n",
        "  SELECT 'Soybean', 'Min Temp', ABS(CORR(avg_yield, avg_temp_min)) FROM soybean UNION ALL\n",
        "  SELECT 'Soybean', 'Precipitation', ABS(CORR(avg_yield, avg_precip)) FROM soybean UNION ALL\n",
        "  SELECT 'Soybean', 'Snowfall', ABS(CORR(avg_yield, avg_snowfall)) FROM soybean UNION ALL\n",
        "  SELECT 'Soybean', 'Snow Depth', ABS(CORR(avg_yield, avg_snow_depth)) FROM soybean\n",
        ")\n",
        "SELECT * FROM correlations"
      ]
    },
    {
      "name": "4176091b",
      "displayName": "Corn Yield Regression Results",
      "queryLines": [
        "SELECT state, year, avg_yield, predicted_yield, residual, avg_temp_max, avg_temp_min, avg_precip, avg_snowfall, avg_snow_depth FROM workspace.number_one_awesome_team.corn_yield_regression_results"
      ]
